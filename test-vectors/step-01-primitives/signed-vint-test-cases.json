{
  "description": "Signed variable-length integer with ZigZag encoding test cases",
  "encoding": "ZigZag encoding maps signed integers to unsigned, then uses vInt encoding",
  "zigzag_formula": "encoded = (value << 1) ^ (value >> 31)",
  "reference": "org.infinispan.commons.io.SignedNumeric.encode()",
  "test_cases": [
    {
      "description": "Zero",
      "value": 0,
      "zigzag_encoded": 0,
      "expected_hex": "00",
      "expected_bytes": [0]
    },
    {
      "description": "Minus one",
      "value": -1,
      "zigzag_encoded": 1,
      "expected_hex": "01",
      "expected_bytes": [1]
    },
    {
      "description": "Plus one",
      "value": 1,
      "zigzag_encoded": 2,
      "expected_hex": "02",
      "expected_bytes": [2]
    },
    {
      "description": "Minus two",
      "value": -2,
      "zigzag_encoded": 3,
      "expected_hex": "03",
      "expected_bytes": [3]
    },
    {
      "description": "Plus two",
      "value": 2,
      "zigzag_encoded": 4,
      "expected_hex": "04",
      "expected_bytes": [4]
    },
    {
      "description": "Minus 64",
      "value": -64,
      "zigzag_encoded": 127,
      "expected_hex": "7F",
      "expected_bytes": [127]
    },
    {
      "description": "Plus 64",
      "value": 64,
      "zigzag_encoded": 128,
      "expected_hex": "80 01",
      "expected_bytes": [128, 1]
    },
    {
      "description": "Minus 65",
      "value": -65,
      "zigzag_encoded": 129,
      "expected_hex": "81 01",
      "expected_bytes": [129, 1]
    },
    {
      "description": "Minus 128",
      "value": -128,
      "zigzag_encoded": 255,
      "expected_hex": "FF 01",
      "expected_bytes": [255, 1]
    },
    {
      "description": "Plus 1000",
      "value": 1000,
      "zigzag_encoded": 2000,
      "expected_hex": "D0 0F",
      "expected_bytes": [208, 15]
    },
    {
      "description": "Minus 1000",
      "value": -1000,
      "zigzag_encoded": 1999,
      "expected_hex": "CF 0F",
      "expected_bytes": [207, 15]
    },
    {
      "description": "Max int32",
      "value": 2147483647,
      "zigzag_encoded": 4294967294,
      "expected_hex": "FE FF FF FF 0F",
      "expected_bytes": [254, 255, 255, 255, 15]
    },
    {
      "description": "Min int32",
      "value": -2147483648,
      "zigzag_encoded": 4294967295,
      "expected_hex": "FF FF FF FF 0F",
      "expected_bytes": [255, 255, 255, 255, 15]
    }
  ],
  "zigzag_decoding": "decoded = (encoded >>> 1) ^ -(encoded & 1)",
  "notes": [
    "ZigZag maps: 0→0, -1→1, 1→2, -2→3, 2→4, etc.",
    "Small negative numbers encode efficiently (e.g., -1 = 1 byte)",
    "Without ZigZag, -1 would encode as 0xFFFFFFFF = 5 bytes!"
  ]
}
